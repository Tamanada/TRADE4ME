# Exchange API Keys
# IMPORTANT: Never commit .env to git!
# Create API keys with TRADE ONLY permissions (no withdrawal!)

# ── Bot principal (scalping) ──
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_API_SECRET=your_api_secret_here
EXCHANGE_NAME=binance
TRADING_MODE=paper

# ── Multi-Exchange (arbitrage) ──
# Ajoutez uniquement les exchanges que vous utilisez
# Format: {EXCHANGE_NAME}_API_KEY / {EXCHANGE_NAME}_API_SECRET

BINANCE_API_KEY=
BINANCE_API_SECRET=

BYBIT_API_KEY=
BYBIT_API_SECRET=

OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_PASSPHRASE=

GATE_API_KEY=
GATE_API_SECRET=

MEXC_API_KEY=
MEXC_API_SECRET=

BITGET_API_KEY=
BITGET_API_SECRET=

HTX_API_KEY=
HTX_API_SECRET=

KRAKEN_API_KEY=
